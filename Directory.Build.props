<Project>
  <PropertyGroup>
    <Authors>XiaEmrys</Authors>
    <Company>XiaEmrys</Company>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/XiaEmrys/WslContainerd.Ollama.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/XiaEmrys/WslContainerd.Ollama</PackageProjectUrl>
    <PackageTags>wsl;ollama;containers;ai</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
</Project>
